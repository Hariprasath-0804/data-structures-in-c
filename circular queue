#include <stdio.h>
int queue[100];
int size=5;
int f=-1;
int r=-1;
void enqueue(int x){
    if((r+1)%size==f)
        printf("Queue is full\n");
    else if(f==-1 || r==-1){
        f=r=0;
        queue[r]=x;
        printf("Value %d enqueued\n",x);
    }
    else{
        r=(r+1)%size;
        queue[r]=x;
        printf("Value %d enqueued\n",x);
    }
}
void dequeue(){
    if(f==-1){
        printf("Queue is empty\n");
    }
    else if(f==r){
        printf("Dequeued element is %d\n",queue[f]);
        f=r=-1;
    }
    else{
        printf("Dequeued element is %d\n",queue[f]);
        f=(f+1)%size;
    }
}
void display(){
    if(f==-1)
        printf("No element to display");
    else{
        printf("Queue elements are\n");
        for(int i=f;;i=(i+1)%size){
            printf("%d ",queue[i]);
            if(i==r)
                break;
        }
        printf("\n");
    }
}
int main()
{
    while(1){
        int ch, x;
        printf("Enter your choice\n");
        printf("1.Enqueue\n 2.Dequeue\n 3.Display\n 4.Exit\n");
        scanf("%d",&ch);
        if(ch==1){
            printf("Enter the value to Enqueue:");
            scanf("%d",&x);
            enqueue(x);
        }
        else if(ch==2)
            dequeue();
        else if(ch==3)
            display();
        else if(ch==4){
            printf("Exiting...");
            break;
        }
        else{
            printf("Invalid choice\n");
        }
    }
    
}
