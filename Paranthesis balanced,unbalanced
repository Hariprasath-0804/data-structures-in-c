#include <stdio.h>
int main()
{
    char s[100];
    scanf("%s",s);
    char stack[100];
    int top=-1,f=0;
    for(int i=0;s[i]!='\0';i++){
        if(s[i]=='{'|| s[i]=='['||s[i]=='('){
            stack[++top]=s[i];
            
        }
        else{
            if(s[i]=='}'){
                if(stack[top]!='{'){
                    f=0;
                    break;
                }
                else{
                    top--;
                    
                }
            }
            if(s[i]==']'){
                if(stack[top]!='['){
                    f=0;
                    break;
            }
            else{
                top--;
            }
        }
        if(s[i]==')'){
            if(stack[top]!='('){
                f=0;
            break;
            }
            else{
                top--;
            }
    }
    if(f==1 && top==-1){
        printf("Balanced ");
    }
    else{
        printf("unbalanced ");
    }
    }
}
