#include <stdio.h>
int eval(int v1,int v2,char op){
    if(op=='+')
        return v2+v1;
    if(op=='-')
        return v2-v1;
    if(op=='*')
        return v2*v1;
    if(op=='/')
        return v2/v1;
}
int main()
{
    char s[100];
    scanf("%s",s);
    int stk[100];
    int top=-1;
    for(int i=0;s[i]!='\0';i++){
        if(s[i]>='0' && s[i] <='9'){
            stk[++top]=s[i]-'0';
        }
        else{
            int v1=stk[top--];
            int v2=stk[top--];
            stk[++top]=eval(v1,v2,s[i]);
        }
    }
    printf("%d",stk[top]);
    
}
